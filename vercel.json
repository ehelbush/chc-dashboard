{
  "rewrites": [
    { "source": "/api/yahoo", "destination": "/api/yahoo.py" },
    { "source": "/api/schwab", "destination": "/api/schwab.py" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
